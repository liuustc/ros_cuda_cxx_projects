{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "source /opt/ros/jazzy/setup.bash 2>/dev/null; cmake",
            "args": [
                "-B", "build",
                "-DBUILD_CUDA_DEMO=ON",
                "-DBUILD_SCHEDULER=ON",
                "-DBUILD_TALKER_LISTENER=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build All",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build", "-j$(nproc)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "CMake: Build Scheduler Only",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build", "--target", "scheduler_lib", "scheduler_tests", "-j$(nproc)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "rm",
            "args": ["-rf", "build"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Test: Run Scheduler Tests",
            "type": "shell",
            "command": "./build/ros2_demo/src/scheduler/scheduler_tests",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": []
        }
    ]
}
